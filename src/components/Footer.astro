<style>
  .site-footer {
    margin: 4rem -1.5rem 0;
    padding: 2rem 1.5rem 2.5rem;
    border-top: 1px solid var(--color-surface-strong);
    font-family: "Victor Mono", ui-monospace, monospace;
    text-align: center;
  }

  .footer-title {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    column-gap: 0.75rem;
    row-gap: 0.4rem;
    align-items: baseline;
  }

  .contact-key {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 400;
    text-align: right;
    justify-self: end;
  }

  .contact-arrow {
    font-size: 0.9rem;
    color: var(--color-mid);
    user-select: none;
  }

  .contact-value {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 600;
    text-align: left;
  }

  .contact-value a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .contact-value a:hover {
    color: var(--color-warm);
  }

  .copyright {
    margin-top: 5rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>

<footer class="site-footer">
  <span class="footer-title">whois</span>
  <div class="contact-grid">
    <span class="contact-key">email</span>
    <span class="contact-arrow">></span>
    <span class="contact-value"><a href="mailto:me@ryanismy.name">me@ryanismy.name</a></span>

    <span class="contact-key">github</span>
    <span class="contact-arrow">></span>
    <span class="contact-value"><a href="https://github.com/rkadlick">rkadlick</a></span>

    <span class="contact-key">linkedin</span>
    <span class="contact-arrow">></span>
    <span class="contact-value"><a href="https://linkedin.com/in/ryankadlick">Ryan Kadlick</a></span>
  </div>
  <p class="copyright">&copy; {new Date().getFullYear()} Ryan Kadlick</p>
</footer>
