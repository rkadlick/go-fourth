---
interface Props {
  name?: string;
}

const { name = "ryanK" } = Astro.props;
---

<style>
  .site-header {
    margin: -2rem -1.5rem 0rem;
    padding: 2.5rem 1.5rem;
    border-bottom: 1px solid var(--color-surface-strong);
    text-align: center;
    font-family: "Victor Mono", ui-monospace, monospace;
  }


  .name-text {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-accent);
  }

  .cursor {
    color: var(--color-warm);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<header class="site-header">
  <span class="name-text">{name}<span class="cursor">_</span></span>
</header>